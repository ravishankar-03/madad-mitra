{
  "entities": {
    "Need": {
      "title": "Resource Need",
      "description": "A resource requirement identified from community surveys.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "description": "Type of resource needed (e.g., Water, Medical)" },
        "urgency": { "type": "string", "enum": ["Low", "Medium", "High", "Critical"], "description": "Urgency level" },
        "location": { "type": "string", "description": "Geographic location of the need" },
        "source_text": { "type": "string", "description": "Original text snippet from survey" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the need was identified" },
        "status": { "type": "string", "enum": ["Pending", "Confirmed", "Fulfilled"], "description": "Current status" },
        "ai_confidence": { "type": "number", "description": "AI confidence score (0-1)" },
        "estimated_impact": { "type": "string", "description": "Estimated number of people or entities impacted" },
        "resource_match": { "type": "string", "description": "Suggested resource for matching" }
      },
      "required": ["type", "urgency", "location", "timestamp", "status"]
    },
    "Activity": {
      "title": "System Activity",
      "description": "Log of system-wide activities.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["survey_processed", "need_flagged", "location_validated", "log_exported"], "description": "Type of activity" },
        "description": { "type": "string", "description": "Short description of the activity" },
        "details": { "type": "string", "description": "Detailed information or metadata" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When it happened" },
        "status": { "type": "string", "enum": ["success", "warning", "info"], "description": "Status level for color coding" }
      },
      "required": ["type", "description", "timestamp", "status"]
    }
  },
  "firestore": {
    "/needs/{needId}": {
      "schema": "Need",
      "description": "Collection of resource needs."
    },
    "/activities/{activityId}": {
      "schema": "Activity",
      "description": "Audit log of activities."
    }
  }
}
